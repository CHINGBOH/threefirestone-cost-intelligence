# RAG Dashboard 环境变量配置
# 复制此文件为 .env 并修改相应配置

# ========== 基础配置 ==========
APP_ENV=dev
APP_DEBUG=true

# ========== 数据库配置 ==========
# Qdrant 向量数据库
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents
# 连接池配置
QDRANT_TIMEOUT=30
QDRANT_POOL_SIZE=10

# Elasticsearch 关键词数据库
ES_HOST=http://localhost:9200
ES_INDEX_NAME=documents
ES_USERNAME=  # 可选，如果需要认证
ES_PASSWORD=  # 可选，如果需要认证
# 连接池配置
ES_MAX_CONNECTIONS=20
ES_TIMEOUT=30

# Neo4j 图数据库
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=  # 必填，生产环境请修改为强密码
NEO4J_DATABASE=neo4j
# 连接池配置
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

# Redis 缓存
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=  # 可选，如果需要认证
REDIS_TTL=3600
# 连接池配置
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=10

# ========== 模型配置 ==========
# Embedding 模型
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_MODEL_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# TEI (Text Embeddings Inference) 配置
# 设置 EMBEDDING_BACKEND=tei 使用 TEI 服务，设为 local 使用本地 sentence-transformers
EMBEDDING_BACKEND=tei
TEI_URL=http://localhost:8003
TEI_MODEL_ID=BAAI/bge-m3
TEI_MAX_BATCH_TOKENS=16384
TEI_MAX_CLIENT_BATCH_SIZE=64

# Reranker 模型
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_MODEL_DEVICE=cpu
RERANKER_BATCH_SIZE=8
RERANKER_MAX_LENGTH=512

# ========== 服务器配置 ==========
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
SERVER_RELOAD=true

# ========== 检索配置 ==========
RETRIEVAL_VECTOR_TOP_K=30
RETRIEVAL_KEYWORD_TOP_K=20
RETRIEVAL_GRAPH_TOP_K=10
RETRIEVAL_SCORE_THRESHOLD=0.6
RETRIEVAL_ENABLE_RERANK=true
RETRIEVAL_ENABLE_FUSION=true

# ========== 分数融合权重 ==========
FUSION_WEIGHT_RERANK=0.4
FUSION_WEIGHT_VECTOR=0.3
FUSION_WEIGHT_KEYWORD=0.2
FUSION_WEIGHT_GRAPH=0.05
FUSION_WEIGHT_TIME=0.05

# ========== 上下文配置 ==========
CONTEXT_MAX_LENGTH=2000
CONTEXT_SURROUNDING_WINDOW=2
CONTEXT_STRATEGY=surrounding

# ========== 日志配置 ==========
LOGGING_LEVEL=INFO
LOGGING_FORMAT=json
LOGGING_OUTPUT=stdout

# ========== LLM API 配置 ==========
# 主 LLM 提供商: openai | claude | kimi | ollama | custom
LLM_PROVIDER=kimi
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.kimi.com/coding/v1
LLM_MODEL=kimi-for-coding
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# OCR 校验专用 LLM (可选，使用较小模型节省成本)
LLM_VERIFY_PROVIDER=kimi
LLM_VERIFY_API_KEY=
LLM_VERIFY_MODEL=kimi-for-coding

# ========== OCR 质量配置 ==========
OCR_QUALITY_THRESHOLD=0.85
OCR_TABLE_INTEGRITY_THRESHOLD=0.90
OCR_MAX_RETRIES=3
OCR_ENABLE_LLM_VERIFY=true

# ========== 服务开关 ==========
# API 服务
SERVICE_API_ENABLED=true
SERVICE_API_PORT=8000

# OCR 服务
SERVICE_OCR_ENABLED=true
SERVICE_OCR_PORT=8001
SERVICE_OCR_GPU=false

# Node.js 递归服务 (默认不启用)
SERVICE_RECURSION_ENABLED=false
SERVICE_RECURSION_PORT=3001
SERVICE_RECURSION_MAX_DEPTH=3

# ========== 结构化存储配置 ==========
# PostgreSQL (表格数据存储)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=your_password_here
# Chinese BM25 text search config (requires zhparser in Postgres image)
# Use "chinese" when running rag-postgres:16-zhparser; falls back to "simple" automatically
PG_TSV_CONFIG=chinese

# ========== 监控配置 ==========
METRICS_ENABLED=true
METRICS_PORT=9090

# ========== Pydantic Settings 环境变量 (使用 __ 作为分隔符) ==========
# 示例: APP__SERVER__HOST=0.0.0.0
#       APP__VECTOR_STORE__HOST=localhost
#       APP__MODELS__EMBEDDING__DEVICE=cuda
# 以下环境变量会被 Pydantic Settings 自动识别
# APP_VECTOR_STORE__HOST=localhost
# APP_VECTOR_STORE__PORT=6333
# APP_GRAPH_STORE__PASSWORD=your_password_here
# APP_MODELS__RERANK__NAME=BAAI/bge-reranker-large
# ==================== Gateway & WebSocket ====================
GATEWAY_PORT=8080
WS_GATEWAY_PORT=8081
NODEJS_URL=http://localhost:3001
PYTHON_URL=http://localhost:8000
OCR_URL=http://localhost:8001
RETRIEVAL_URL=http://localhost:8002
LLM_URL=http://localhost:8003
