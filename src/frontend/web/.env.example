# Frontend Environment Configuration
# Copy this file to .env and adjust as needed

# API Gateway base URL (HTTP)
# Leave empty for development to use Vite proxy
VITE_API_BASE_URL=

# WebSocket Gateway URL
# In development, Vite proxy handles /ws -> ws://localhost:8081
# For direct connection, use: ws://localhost:8081/ws?room=dashboard
VITE_WS_URL=
